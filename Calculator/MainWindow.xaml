<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator"
        mc:Ignorable="d"
        Title="Calculator" Height="550" Width="450" ResizeMode="CanMinimize">
    <Window.DataContext>
        <local:FrontendViewModel/>
    </Window.DataContext>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Height="34"
                Margin="0,0,0,10"
                Padding="8,0"
                BorderBrush="#FFD0D0D0"
                BorderThickness="1"
                CornerRadius="4"
                Background="#FFF7F7F7">
            <TextBlock VerticalAlignment="Center"
                       Foreground="#FF666666"
                       FontStyle="Italic"
                       Text="Reserved space for future menu bar"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBox x:Name="UpperTextBox"
                     Margin="0,0,0,6"
                     Padding="8"
                     FontSize="22"
                     HorizontalContentAlignment="Right"
                     VerticalContentAlignment="Center"
                     Height="46"
                     Text="{Binding UpperText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            <TextBox x:Name="LowerTextBox"
                     Padding="8"
                     FontSize="28"
                     FontWeight="SemiBold"
                     HorizontalContentAlignment="Right"
                     VerticalContentAlignment="Center"
                     Height="52"
                     Text="{Binding LowerText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.Resources>
                <Style x:Key="NumberButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                    <Setter Property="Command" Value="{Binding NumberCommand}"/>
                    <Setter Property="CommandParameter" Value="{Binding Content, RelativeSource={RelativeSource Self}}"/>
                </Style>
            </Grid.Resources>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="1" Rows="6" Columns="5">
                <UniformGrid.Resources>
                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}"/>
                </UniformGrid.Resources>

                <Button Content="C" Margin="4" Style="{StaticResource MaterialDesignRaisedButton}"/>
                <Button Content="CE" Margin="4" Style="{StaticResource MaterialDesignRaisedButton}"/>
                <Button Content="⌫" Margin="4" Style="{StaticResource MaterialDesignRaisedButton}"/>
                <Button Content="(" Margin="4"/>
                <Button Content=")" Margin="4"/>

                <Button Content="sin" Margin="4"/>
                <Button Content="cos" Margin="4"/>
                <Button Content="tan" Margin="4"/>
                <Button Content="log" Margin="4"/>
                <Button Content="√" Margin="4"/>

                <Button Content="xʸ" Margin="4"/>
                <Button Content="x²" Margin="4"/>
                <Button Content="7" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="8" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="9" Margin="4" Style="{StaticResource NumberButton}"/>

                <Button Content="+" Margin="4"/>
                <Button Content="-" Margin="4"/>
                <Button Content="4" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="5" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="6" Margin="4" Style="{StaticResource NumberButton}"/>

                <Button Content="×" Margin="4"/>
                <Button Content="÷" Margin="4"/>
                <Button Content="1" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="2" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="3" Margin="4" Style="{StaticResource NumberButton}"/>

                <Button Content="e" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="π" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="0" Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="." Margin="4" Style="{StaticResource NumberButton}"/>
                <Button Content="=" Margin="4" Style="{StaticResource MaterialDesignRaisedButton}"/>
            </UniformGrid>
        </Grid>
    </Grid>
</Window>
